# Neon (auto-populated by vite-plugin-neon-new on first dev run)
DATABASE_URL=
DATABASE_URL_POOLER=

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Sentry (error monitoring)
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# SerpAPI (server-side only, read by src/server/serpapi.ts)
SERPAPI_API_KEY=
# Optional override; default: google. Other values: bing, duckduckgo, baidu, yahoo.
SERPAPI_ENGINE=google

# OpenRouter (server-side only, read by src/server/openrouter.ts)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
APP_URL=http://localhost:3000
